# ============================================================
# EnglishFlow API — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- Server ---
NODE_ENV=development
PORT=3000

# --- Database (PostgreSQL) ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/englishflow"

# --- Cache (Redis) ---
REDIS_URL="redis://localhost:6379"

# --- Auth ---
JWT_SECRET="change-me-in-production-use-a-long-random-string"
JWT_EXPIRES_IN="7d"

# --- Supabase (optional — only needed if using Supabase Auth) ---
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""

# --- RevenueCat (in-app purchases) ---
REVENUECAT_WEBHOOK_SECRET=""

# ============================================================
# EXTERNAL APIs — FREE TIER (no key required)
# ============================================================

# Free Dictionary API: https://api.dictionaryapi.dev
# No key needed. Used for word definitions, IPA, audio.

# Datamuse API: https://api.datamuse.com
# No key needed. Used for synonyms, antonyms, collocations.

# Tatoeba: https://tatoeba.org/eng/downloads
# No key needed. Dataset imported locally into Postgres via script.

# ============================================================
# EXTERNAL APIs — KEY REQUIRED
# ============================================================

# --- LanguageTool (grammar correction) ---
# Self-host (recommended): docker compose up languagetool
# Or use the public API (limited): https://languagetool.org/http-api/
LANGUAGETOOL_URL="http://localhost:8010/v2"
LANGUAGETOOL_API_KEY=""   # leave empty for self-hosted, fill for Premium

# --- Groq (LLM — free tier) ---
# Create account: https://console.groq.com
# Free tier: generous rate limits with LLaMA 3.3 70B
GROQ_API_KEY=""
GROQ_MODEL="llama-3.3-70b-versatile"

# --- DeepL (translation — 500K chars/month free) ---
# Create account: https://www.deepl.com/pro-api
# Free tier API URL ends with /v2 on api-free.deepl.com
DEEPL_API_KEY=""
DEEPL_API_URL="https://api-free.deepl.com/v2"

# --- Amazon Polly (TTS — pay-per-use, free tier 1M chars/month) ---
# Create IAM user with AmazonPollyFullAccess + S3 permissions
AWS_REGION="eu-west-3"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
POLLY_VOICE_ID="Joanna"
POLLY_S3_BUCKET="englishflow-audio-cache"

# --- Anthropic Claude (LLM Premium) ---
# Create account: https://console.anthropic.com
ANTHROPIC_API_KEY=""

# --- OpenAI (alternative LLM Premium) ---
# Create account: https://platform.openai.com
OPENAI_API_KEY=""

# --- CDN / S3 public base URL ---
S3_PUBLIC_URL="https://cdn.englishflow.com"
