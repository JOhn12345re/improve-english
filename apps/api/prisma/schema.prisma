generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CefrLevel {
  A1
  A2
  B1
  B2
  C1
  C2
}

enum NativeLanguage {
  fr
  en
  es
  it
  ar
  pt
  de
}

enum LearningGoal {
  travel
  work
  studies
  leisure
  other
}

enum SubscriptionPlan {
  free
  premium_monthly
  premium_yearly
}

enum SubscriptionStatus {
  active
  expired
  cancelled
  trial
}

enum ContentSource {
  VOA_BEGINNING
  VOA_INTERMEDIATE
  VOA_ADVANCED
  GITHUB_OER
  ARCHIVE_ORG
  GUTENBERG
  WIKIPEDIA_SIMPLE
  MANUAL_UPLOAD
}

enum IngestionStatus {
  PENDING
  CLASSIFIED
  GENERATING
  COMPLETED
  FAILED
  REJECTED
}

enum JobStatus {
  RUNNING
  COMPLETED
  FAILED
}

model User {
  id              String         @id @default(uuid())
  email           String         @unique
  native_language NativeLanguage @default(fr)
  level           CefrLevel      @default(A1)
  daily_goal      Int            @default(10)
  learning_goal   LearningGoal   @default(other)
  streak          Int            @default(0)
  last_activity   DateTime?
  timezone        String         @default("Europe/Paris")
  xp              Int            @default(0)
  created_at      DateTime       @default(now())
  updated_at      DateTime       @updatedAt
  deleted_at      DateTime?      // Soft delete (RGPD)

  progress        UserProgress[]
  vocabulary      UserVocabulary[]
  subscription    Subscription?

  @@index([email])
  @@index([deleted_at])
}

model Lesson {
  id              String       @id @default(uuid())
  level           CefrLevel
  theme           String
  order           Int
  content_json    Json
  is_premium      Boolean      @default(false)
  created_at      DateTime     @default(now())
  raw_content_id  String?

  progress        UserProgress[]
  raw_content     RawContent?  @relation(fields: [raw_content_id], references: [id], onDelete: SetNull)

  @@unique([level, order])
  @@index([level])
  @@index([raw_content_id])
}

model UserProgress {
  id           String   @id @default(uuid())
  user_id      String
  lesson_id    String
  score        Float    @default(0)
  completed_at DateTime @default(now())
  attempts     Int      @default(1)

  user   User   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lesson_id], references: [id], onDelete: Cascade)

  @@unique([user_id, lesson_id])
  @@index([user_id])
  @@index([lesson_id])
  @@index([user_id, completed_at])
}

model VocabularyWord {
  id                String         @id @default(uuid())
  word_en           String         @unique
  translations_json Json
  level             CefrLevel
  audio_url         String?
  created_at        DateTime       @default(now())

  user_vocabulary   UserVocabulary[]

  @@index([level])
}

model UserVocabulary {
  id            String   @id @default(uuid())
  user_id       String
  word_id       String
  mastery_level Float    @default(0)
  stability     Float    @default(1)   // FSRS: stabilite
  difficulty    Float    @default(5)   // FSRS: difficulte
  reps          Int      @default(0)
  lapses        Int      @default(0)
  next_review_at DateTime @default(now())
  last_review_at DateTime?

  user User           @relation(fields: [user_id], references: [id], onDelete: Cascade)
  word VocabularyWord @relation(fields: [word_id], references: [id], onDelete: Cascade)

  @@unique([user_id, word_id])
  @@index([user_id])
  @@index([user_id, next_review_at])
}

// ── Tatoeba ────────────────────────────────────────────────────────────────

model TatoebaSentence {
  id           Int        @id             // Original Tatoeba sentence ID
  lang         String     @db.VarChar(3)  // ISO 639-3: 'eng', 'fra', 'spa', etc.
  text         String
  lengthChars  Int
  cecrlLevel   CefrLevel?

  // Links where this sentence is the source (EN side)
  linksAsSource TatoebaLink[] @relation("SourceSentence")
  // Links where this sentence is the translation
  linksAsTarget TatoebaLink[] @relation("TargetSentence")

  @@index([lang])
  @@index([lang, cecrlLevel])
  @@index([cecrlLevel])
}

model TatoebaLink {
  id             Int @id @default(autoincrement())
  sourceLang     String @db.VarChar(3)
  targetLang     String @db.VarChar(3)
  sourceId       Int
  targetId       Int

  source TatoebaSentence @relation("SourceSentence", fields: [sourceId], references: [id], onDelete: Cascade)
  target TatoebaSentence @relation("TargetSentence", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([sourceId, targetId])
  @@index([sourceLang, targetLang])
  @@index([sourceId])
  @@index([targetId])
}

// ── Content Ingestion ───────────────────────────────────────────────────────

model RawContent {
  id              String          @id @default(cuid())
  source          ContentSource
  source_url      String          @unique
  source_meta     Json
  title           String
  text            String          @db.Text
  audio_url       String?
  language        String          @default("en")
  detected_level  CefrLevel?
  topics          String[]
  word_count      Int
  avg_word_freq   Float?
  status          IngestionStatus @default(PENDING)
  ingested_at     DateTime        @default(now())
  processed_at    DateTime?

  generated_lessons Lesson[]

  @@index([source, status])
  @@index([detected_level])
  @@index([status])
}

model IngestionJob {
  id              String        @id @default(cuid())
  source          ContentSource
  started_at      DateTime      @default(now())
  finished_at     DateTime?
  items_found     Int           @default(0)
  items_imported  Int           @default(0)
  items_skipped   Int           @default(0)
  items_failed    Int           @default(0)
  error_log       Json?
  status          JobStatus     @default(RUNNING)

  @@index([source, status])
  @@index([started_at])
}

// ── Subscriptions ──────────────────────────────────────────────────────────

model Subscription {
  id             String             @id @default(uuid())
  user_id        String             @unique
  plan           SubscriptionPlan   @default(free)
  status         SubscriptionStatus @default(active)
  started_at     DateTime           @default(now())
  expires_at     DateTime?
  trial_ends_at  DateTime?
  revenuecat_id  String?            @unique
  created_at     DateTime           @default(now())
  updated_at     DateTime           @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([revenuecat_id])
  @@index([status])
}
